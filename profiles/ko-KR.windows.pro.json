{
  "profileName": "ko-KR.windows.pro",
  "browser": {
    "channel": "chrome-user-session",
    "platform": "windows",
    "locale": "ko-KR"
  },
  "chatgpt": {
    "mode": "auto",
    "projectName": null,
    "uiTier": "pro"
  },
  "attachments": {
    "enabled": true,
    "strategy": "visible-menu-only"
  },
  "ui": {
    "project": {
      "entry": {
        "roles": [{ "role": "button", "name": "프로젝트" }, { "role": "button", "name": "Projects" }],
        "labels": ["프로젝트", "Projects"],
        "texts": ["프로젝트", "Projects"],
        "selectors": ["button[aria-label*='프로젝트']", "button:has-text('프로젝트')", "button:has-text('Projects')"]
      },
      "search": {
        "roles": [{ "role": "textbox", "name": "프로젝트 검색" }, { "role": "textbox", "name": "Search projects" }],
        "labels": ["프로젝트 검색", "Search projects"],
        "texts": ["프로젝트 검색", "Search projects"],
        "placeholders": ["프로젝트 검색", "Search projects"],
        "selectors": ["input[aria-label*='프로젝트']", "input[placeholder*='프로젝트']", "input[placeholder*='Search']"]
      },
      "list": {
        "roles": [{ "role": "menuitem" }, { "role": "option" }],
        "selectors": ["[role='menu'] [role='menuitem']", "[role='listbox'] [role='option']", "a[href*='/g/']"]
      }
    },
    "newChat": {
      "roles": [{ "role": "link", "name": "새 채팅" }, { "role": "button", "name": "새 채팅" }, { "role": "button", "name": "New chat" }],
      "labels": ["새 채팅", "New chat"],
      "texts": ["새 채팅", "New chat"],
      "selectors": ["a[aria-label*='새 채팅']", "button[aria-label*='새 채팅']", "a:has-text('새 채팅')", "button:has-text('New chat')"]
    },
    "promptBox": {
      "roles": [{ "role": "textbox", "name": "메시지 ChatGPT" }, { "role": "textbox", "name": "Message ChatGPT" }],
      "labels": ["무엇을 도와드릴까요?", "메시지 ChatGPT", "Message ChatGPT"],
      "texts": ["무엇을 도와드릴까요?", "메시지 ChatGPT", "Message ChatGPT"],
      "placeholders": ["무엇을 도와드릴까요?", "메시지 ChatGPT", "Message ChatGPT"],
      "selectors": ["textarea", "div[contenteditable='true']", "[role='textbox']"]
    },
    "submit": {
      "roles": [{ "role": "button", "name": "보내기" }, { "role": "button", "name": "Send prompt" }, { "role": "button", "name": "전송" }],
      "labels": ["보내기", "Send prompt", "전송"],
      "texts": ["보내기", "Send", "전송"],
      "selectors": ["button[aria-label*='보내기']", "button[aria-label*='Send']", "button[data-testid='send-button']"]
    },
    "modeMenu": {
      "entry": {
        "roles": [{ "role": "button", "name": "최신" }, { "role": "button", "name": "최신 모드" }, { "role": "button", "name": "Instant" }, { "role": "button", "name": "Thinking" }, { "role": "button", "name": "Pro" }, { "role": "button", "name": "Pro 확장 모드" }],
        "labels": ["모델 선택", "모델", "Model"],
        "texts": ["최신", "최신 모드", "Instant", "Thinking", "Pro", "Pro 확장 모드", "구성..."],
        "selectors": ["button[aria-haspopup='menu']", "button:has-text('최신')", "button:has-text('Instant')", "button:has-text('Thinking')", "button:has-text('Pro')"]
      },
      "options": {
        "auto": {
          "roles": [{ "role": "menuitem", "name": "최신" }, { "role": "option", "name": "Latest" }],
          "labels": ["최신", "Latest"],
          "texts": ["최신", "Latest"],
          "selectors": ["[role='menuitem']:has-text('최신')", "[role='option']:has-text('Latest')"]
        },
        "latest": {
          "roles": [{ "role": "menuitem", "name": "최신" }, { "role": "option", "name": "Latest" }],
          "labels": ["최신", "Latest"],
          "texts": ["최신", "Latest"],
          "selectors": ["[role='menuitem']:has-text('최신')", "[role='option']:has-text('Latest')"]
        },
        "instant": {
          "roles": [{ "role": "menuitem", "name": "Instant" }, { "role": "option", "name": "Instant" }],
          "labels": ["Instant"],
          "texts": ["Instant"],
          "selectors": ["[role='menuitem']:has-text('Instant')", "[role='option']:has-text('Instant')"]
        },
        "thinking": {
          "roles": [{ "role": "menuitem", "name": "Thinking" }, { "role": "option", "name": "Thinking" }],
          "labels": ["Thinking"],
          "texts": ["Thinking"],
          "selectors": ["[role='menuitem']:has-text('Thinking')", "[role='option']:has-text('Thinking')"]
        },
        "pro": {
          "roles": [{ "role": "menuitem", "name": "Pro" }, { "role": "option", "name": "Pro" }, { "role": "button", "name": "Pro" }, { "role": "button", "name": "Pro 확장 모드" }],
          "labels": ["Pro"],
          "texts": ["Pro", "Pro 확장 모드"],
          "selectors": ["[role='menuitem']:has-text('Pro')", "[role='option']:has-text('Pro')"]
        }
      },
      "overflow": {
        "roles": [{ "role": "menuitem", "name": "구성..." }, { "role": "menuitem", "name": "More models" }],
        "labels": ["구성...", "More models"],
        "texts": ["구성...", "More models"],
        "selectors": ["[role='menuitem']:has-text('구성...')", "[role='menuitem']:has-text('More models')"]
      }
    },
    "toolsMenu": {
      "entry": {
        "roles": [{ "role": "button", "name": "도구" }, { "role": "button", "name": "Tools" }, { "role": "button", "name": "+" }],
        "labels": ["도구", "Tools", "첨부"],
        "texts": ["도구", "Tools", "+"],
        "selectors": ["button[aria-label*='도구']", "button[aria-label*='Tools']", "button:has-text('+')"]
      },
      "items": {
        "upload": {
          "roles": [{ "role": "menuitem", "name": "사진 및 파일 업로드" }, { "role": "menuitem", "name": "Upload photos and files" }],
          "labels": ["사진 및 파일 업로드", "Upload photos and files"],
          "texts": ["사진 및 파일 업로드", "Upload photos and files"],
          "selectors": ["[role='menuitem']:has-text('사진 및 파일 업로드')", "[role='menuitem']:has-text('Upload photos and files')"]
        },
        "recent": {
          "roles": [{ "role": "menuitem", "name": "최근 파일" }, { "role": "menuitem", "name": "Recent files" }],
          "labels": ["최근 파일", "Recent files"],
          "texts": ["최근 파일", "Recent files"],
          "selectors": ["[role='menuitem']:has-text('최근 파일')", "[role='menuitem']:has-text('Recent files')"]
        },
        "deepResearch": {
          "roles": [{ "role": "menuitem", "name": "심층 리서치" }, { "role": "menuitem", "name": "Deep research" }],
          "labels": ["심층 리서치", "Deep research"],
          "texts": ["심층 리서치", "Deep research"],
          "selectors": ["[role='menuitem']:has-text('심층 리서치')", "[role='menuitem']:has-text('Deep research')"]
        },
        "shoppingAssistant": {
          "roles": [{ "role": "menuitem", "name": "쇼핑 어시스턴트" }, { "role": "menuitem", "name": "Shopping assistant" }],
          "labels": ["쇼핑 어시스턴트", "Shopping assistant"],
          "texts": ["쇼핑 어시스턴트", "Shopping assistant"],
          "selectors": ["[role='menuitem']:has-text('쇼핑 어시스턴트')", "[role='menuitem']:has-text('Shopping assistant')"]
        },
        "webSearch": {
          "roles": [{ "role": "menuitem", "name": "웹 검색" }, { "role": "menuitem", "name": "Web search" }],
          "labels": ["웹 검색", "Web search"],
          "texts": ["웹 검색", "Web search"],
          "selectors": ["[role='menuitem']:has-text('웹 검색')", "[role='menuitem']:has-text('Web search')"]
        },
        "study": {
          "roles": [{ "role": "menuitem", "name": "공부하기" }, { "role": "menuitem", "name": "Study and learn" }],
          "labels": ["공부하기", "Study and learn"],
          "texts": ["공부하기", "Study and learn"],
          "selectors": ["[role='menuitem']:has-text('공부하기')", "[role='menuitem']:has-text('Study and learn')"]
        },
        "more": {
          "roles": [{ "role": "menuitem", "name": "더 보기" }, { "role": "menuitem", "name": "More" }],
          "labels": ["더 보기", "More"],
          "texts": ["더 보기", "More"],
          "selectors": ["[role='menuitem']:has-text('더 보기')", "[role='menuitem']:has-text('More')"]
        }
      }
    }
  }
}
