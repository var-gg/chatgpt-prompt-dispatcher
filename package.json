{
  "name": "chatgpt-prompt-dispatcher",
  "version": "0.1.0",
  "description": "Local browser automation for dispatching prompts into a logged-in ChatGPT web session on Windows.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "chatgpt-prompt-dispatcher": "src/index.js"
  },
  "scripts": {
    "dev": "node src/dev.js",
    "lint": "node src/lint.js",
    "test": "node --test tests/*.test.js",
