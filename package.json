    "build": "node src/build.js",
    "pack-skill": "node src/pack-skill.js",
    "install-local": "node src/install-local.js",
    "submit": "node src/index.js submit-chatgpt"
  },
  "keywords": [
    "chatgpt",
    "browser-automation",
    "windows",
    "openclaw",
    "skill"
  ],
